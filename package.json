{
  "name": "openbanking-api-gateway",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint:openapi": "spectral lint docs/api-specs/*.yaml",
    "test:postman": "node tests/api-contract-tests/validate-postman-collection.js",
    "test:mock-server": "node tests/api-contract-tests/validate-mock-server.js",
    "test": "npm run lint:openapi && npm run test:postman && npm run test:mock-server",
    "mock:sandbox": "node src/mock-server/sandbox-server.js",
    "mock:accounts": "prism mock docs/api-specs/openapi-accounts.yaml --port 4010",
    "mock:consents": "prism mock docs/api-specs/openapi-consents.yaml --port 4011",
    "mock:payments": "prism mock docs/api-specs/openapi-payments.yaml --port 4012",
    "mock:events": "prism mock docs/api-specs/openapi-events.yaml --port 4013"
  },
  "devDependencies": {
    "@stoplight/prism-cli": "^5.14.2",
    "@stoplight/spectral-cli": "^6.11.1"
  }
}
